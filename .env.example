# All variables are OPTIONAL — the defaults work with a standard Hermes
# install at ~/.hermes/hermes-agent.

# Hermes checkout the ACP adapter runs from (default ~/.hermes/hermes-agent)
# HERMES_ACP_HOME=

# Python used to spawn the adapter (default <HERMES_ACP_HOME>/venv/bin/python)
# HERMES_ACP_PYTHON=

# Set to 1 to surface the agent's stderr in the dev server output
# ACP_DEBUG=

# Per-profile home overrides for registry entries with an envHomeKey,
# e.g. ASEL_HERMES_HOME= (default ~/.hermes/profiles/<profileName>)
