+    def remove_all_sessions(self) -> int:
+        """Remove every ACP session from memory and the database.
+
+        Only rows with ``source='acp'`` are touched — CLI/Telegram/cron
+        sessions sharing the same state.db are left alone. Returns the
+        number of distinct sessions removed.
+        """
+        with self._lock:
+            memory_ids = list(self._sessions.keys())
+            self._sessions.clear()
+        for sid in memory_ids:
+            _clear_task_cwd(sid)
+
+        db = self._get_db()
+        db_ids: List[str] = []
+        if db is not None:
+            try:
+                db_ids = [
+                    str(row["id"])
+                    for row in db.list_sessions_rich(
+                        source="acp",
+                        limit=100_000,
+                        include_children=True,
+                        project_compression_tips=False,
+                    )
+                ]
+            except Exception:
+                logger.debug("Failed to enumerate ACP sessions for bulk delete", exc_info=True)
+
+        all_ids = list(dict.fromkeys(memory_ids + db_ids))
+        if db is not None and all_ids:
+            try:
+                db.delete_sessions(all_ids)
+            except Exception:
+                logger.debug("Bulk ACP session delete failed", exc_info=True)
+        logger.info("Removed %d ACP sessions (bulk delete)", len(all_ids))
+        return len(all_ids)
+
