+    # ---- Extension methods (`_`-prefixed JSON-RPC) --------------------------
+
+    async def ext_method(self, method: str, params: dict[str, Any]) -> dict[str, Any]:
+        """Handle `_`-prefixed extension requests (router strips the prefix).
+
+        ACP has no standard session-deletion method, so clients (aselAI web
+        UI) call these as protocol extensions:
+
+        * ``_session/delete``     — params ``{"sessionId": str}``
+        * ``_session/delete_all`` — no params; only ``source='acp'`` rows
+        """
+        if method == "session/delete":
+            session_id = params.get("sessionId") or params.get("session_id")
+            if not isinstance(session_id, str) or not session_id:
+                raise acp.RequestError.invalid_params({"sessionId": "required"})
+            deleted = await asyncio.to_thread(
+                self.session_manager.remove_session, session_id
+            )
+            logger.info("Extension session/delete %s -> deleted=%s", session_id, deleted)
+            return {"deleted": deleted}
+
+        if method == "session/delete_all":
+            count = await asyncio.to_thread(self.session_manager.remove_all_sessions)
+            logger.info("Extension session/delete_all -> removed %d sessions", count)
+            return {"deleted": count}
+
+        raise acp.RequestError.method_not_found(f"_{method}")
+
